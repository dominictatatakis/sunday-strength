# Copy to .env and fill in. Load with: set -a; source .env; set +a

# Where the app is served (used in email links)
APP_BASE_URL=http://localhost:8000

# Signing key for manage/unsubscribe links — generate with: openssl rand -hex 32
SECRET_KEY=

# Stripe (leave empty for DEV MODE: signups activate without payment)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# From scripts/stripe_setup.py:
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_QUARTERLY=

# Google SSO (optional — buttons appear when both are set).
# console.cloud.google.com → APIs & Services → Credentials → OAuth client ID
# (Web application). Authorised redirect URI: <APP_BASE_URL>/auth/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (resend.com — free tier 3,000 emails/month). Empty = dry-run to stdout.
RESEND_API_KEY=
EMAIL_FROM=Sunday Strength <plan@yourdomain.com>

# Beta alternative: send via your own Gmail to anyone (~500/day).
# Takes priority over Resend when both are set. App password:
# Google Account -> Security -> 2-Step Verification -> App passwords.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# SQLite location (defaults to ./gymdigest.db)
#DB_PATH=
